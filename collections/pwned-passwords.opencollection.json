{
  "opencollection": "1.0.0",
  "info": {
    "name": "Pwned Passwords API",
    "version": "2.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Range Search",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search By Hash Range",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.pwnedpasswords.com/range/:hashPrefix",
            "headers": [
              {
                "name": "Add-Padding",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "hashPrefix",
                "value": "",
                "type": "path",
                "description": "First 5 characters of the SHA-1 (or NTLM) password hash, uppercase hex."
              },
              {
                "name": "mode",
                "value": "",
                "type": "query",
                "description": "Hash algorithm. Default is SHA-1; set `ntlm` for NTLM hashes."
              }
            ]
          },
          "docs": "Returns suffixes of all SHA-1 (or NTLM) hashes that begin with the supplied 5-character\nprefix, alongside the number of times each hash was observed in breaches.\n"
        }
      ]
    }
  ],
  "bundled": true
}