{
  "item": [
    {
      "id": "91607ac7-6cae-40dd-a15a-420f6600727c",
      "name": "Range Search",
      "description": {
        "content": "K-anonymity range search for password hashes.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "e4205365-bb82-4c6f-a9b4-4b47cd7f351a",
          "name": "Search By Hash Range",
          "request": {
            "name": "Search By Hash Range",
            "description": {
              "content": "Returns suffixes of all SHA-1 (or NTLM) hashes that begin with the supplied 5-character\nprefix, alongside the number of times each hash was observed in breaches.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "range",
                ":hashPrefix"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "mode",
                  "value": "sha1",
                  "description": "Hash algorithm. Default is SHA-1; set `ntlm` for NTLM hashes."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "hashPrefix",
                  "description": "(Required) First 5 characters of the SHA-1 (or NTLM) password hash, uppercase hex."
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "When `true`, the response is padded to 800-1,000 entries to mask the response size.",
                "key": "Add-Padding",
                "value": "<boolean>"
              },
              {
                "key": "Accept",
                "value": "text/plain"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "e4bd530d-8e32-4d8f-8176-3d3a6f13202f",
              "name": "A newline-separated list of `HASHSUFFIX:COUNT` entries. The endpoint always returns\n200; absence of the queried suffix indicates the password is not known to HIBP.\n",
              "originalRequest": {
                "url": {
                  "path": [
                    "range",
                    ":hashPrefix"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "mode",
                      "value": "sha1"
                    }
                  ],
                  "variable": [
                    {
                      "disabled": false,
                      "type": "any",
                      "value": "<string>",
                      "key": "hashPrefix",
                      "description": "(Required) First 5 characters of the SHA-1 (or NTLM) password hash, uppercase hex."
                    }
                  ]
                },
                "header": [
                  {
                    "disabled": false,
                    "description": "When `true`, the response is padded to 800-1,000 entries to mask the response size.",
                    "key": "Add-Padding",
                    "value": "<boolean>"
                  },
                  {
                    "key": "Accept",
                    "value": "text/plain"
                  }
                ],
                "method": "GET",
                "body": {}
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ],
              "body": "0018A45C4D1DEF81644B54AB7F969B88D65:1\n00D4F6E8FA6EECAD2A3AA415EEC418D38EC:2\n",
              "cookie": [],
              "_postman_previewlanguage": "text"
            }
          ],
          "event": [],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          }
        }
      ],
      "event": []
    }
  ],
  "event": [],
  "variable": [
    {
      "type": "string",
      "value": "https://api.pwnedpasswords.com",
      "key": "baseUrl"
    }
  ],
  "info": {
    "_postman_id": "95d48bd9-3b90-443b-8d76-53d8e96756f7",
    "name": "Pwned Passwords API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Pwned Passwords is a free k-anonymity-based lookup service that exposes whether a password\nappears in any of the public credential corpora ingested by Have I Been Pwned. Clients\nsubmit the first five characters of the SHA-1 (or NTLM) hash of a password and receive\na list of matching hash suffixes with their breach counts. No authentication is required.\n\n\nContact Support:\n Name: Pwned Passwords",
      "type": "text/plain"
    }
  }
}